---
import Layout from '@layouts/Layout.astro';
import About from '@components/home/About.astro';
import Companies from '@components/home/Companies.astro';
import Cta from '@components/home/Cta.astro';
import Expertise from '@components/home/Expertise.astro';
import Hero from '@components/home/Hero.astro';
import Services from '@components/home/Services.astro';
import { getLabels, locales, defaultLocale, prefixDefaultLocale } from '@i18n/utils';
export { getStaticPaths } from '@i18n/utils';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const labels = getLabels(Astro.currentLocale, 'home');
---

<Layout description={labels.description} title={labels.title}>
  <script slot="head" is:inline define:vars={{ base, currentPath, locales, defaultLocale, prefixDefaultLocale }}>
    if (currentPath === base + '/') {
      const preferred = localStorage.getItem('language') || navigator.language.split('-')[0];
      const lang = preferred && locales.includes(preferred) ? preferred : defaultLocale;
      (lang !== defaultLocale || prefixDefaultLocale) && location.replace(base + '/' + lang + '/');
    }
  </script>
  <Hero />
  <Services />
  <Expertise />
  <About />
  <Companies />
  <Cta />
</Layout>
